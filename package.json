{
  "name": "zerotoship",
  "version": "0.1.0",
  "description": "Automated SaaS that scrapes the web for pain points and generates business ideas",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*",
    "web"
  ],
  "scripts": {
    "build": "npm run build --workspace=@zerotoship/shared && tsc",
    "dev": "ts-node src/index.ts",
    "dev:api": "ts-node src/api/server.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "db:seed": "ts-node scripts/db-seed.ts",
    "db:verify": "ts-node scripts/db-verify.ts",
    "scheduler": "ts-node src/scheduler/cli.ts",
    "scheduler:run": "ts-node src/scheduler/cli.ts run",
    "scheduler:dry-run": "ts-node src/scheduler/cli.ts run --dry-run",
    "scheduler:start": "ts-node src/scheduler/cli.ts schedule",
    "scheduler:health": "ts-node src/scheduler/cli.ts health",
    "validate-costs": "npx tsx src/cli/validate-costs.ts",
    "web:dev": "npm run dev --prefix web",
    "web:build": "npm run build --prefix web",
    "web:start": "npm run start --prefix web",
    "web:lint": "npm run lint --prefix web",
    "web:test:e2e": "npm run test:e2e --prefix web",
    "web:test:e2e:ui": "npm run test:e2e:ui --prefix web",
    "web:test": "npm run test --prefix web"
  },
  "keywords": [
    "saas",
    "scraper",
    "ideas",
    "business"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@octokit/rest": "^20.0.2",
    "@octokit/types": "^12.4.0",
    "@sentry/node": "^8.0.0",
    "@supabase/supabase-js": "^2.39.3",
    "@zerotoship/shared": "*",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.29.3",
    "fastify": "^4.26.0",
    "fastify-type-provider-zod": "^1.1.9",
    "ioredis": "^5.9.2",
    "node-cron": "^3.0.3",
    "pino": "^9.0.0",
    "pino-pretty": "^10.3.1",
    "postgres": "^3.4.3",
    "stripe": "^20.3.0",
    "svix": "^1.84.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.20.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vitest": "^1.1.0"
  }
}
