# ===========================================
# ZeroToShip Environment Configuration
# ===========================================

# GitHub API Token (required for higher rate limits - 5000/hour)
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo (read-only access to public repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ===========================================
# AI Provider Keys
# ===========================================

# Anthropic API Key (required for scoring and brief generation)
# Create at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# OpenAI API Key (required for embeddings/clustering only)
# Create at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ===========================================
# Supabase Configuration (Database + Auth)
# ===========================================

# Database URL (from Supabase Dashboard > Settings > Database)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase Project URL (from Supabase Dashboard > Settings > API)
# Format: https://[project-ref].supabase.co
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase Service Role Key (from Supabase Dashboard > Settings > API > service_role key)
# WARNING: Keep this secret - it bypasses Row Level Security
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx

# Google OAuth (for backend code exchange — used by POST /api/v1/auth/google)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# Supabase Public Keys (for frontend OAuth)
# These are safe to expose — they only allow public operations
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx

# ===========================================
# Email (Resend)
# ===========================================

# Resend API Key (for email delivery)
# Create at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ===========================================
# Monitoring & Alerting
# ===========================================

# Sentry DSN (optional error tracking)
# Create at: https://sentry.io/settings/projects/
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxx.ingest.sentry.io/1234567

# Comma-separated email recipients for operational alerts
# ALERT_EMAIL=ops@yourdomain.com,founder@yourdomain.com

# Slack incoming webhook URL for alerts
# ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/T00000000/B00000000/xxxxxxxxxxxxxxxx

# Alert deduplication cooldown window in minutes
ALERT_COOLDOWN_MINUTES=60

# Optional PagerDuty Events API routing key (future use)
# PAGERDUTY_ROUTING_KEY=xxxxxxxxxxxxxxxxxxxx

# SMS alerts via Twilio (optional)
# ALERT_SMS_TO=+15417436383
# ALERT_SMS_FROM=+15551234567
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Watchdog threshold: alert if no successful run within N hours
WATCHDOG_MAX_SUCCESS_AGE_HOURS=30

# ===========================================
# Optional: Web Search APIs (for gap analysis)
# ===========================================

# SerpAPI Key (Google search results)
# Create at: https://serpapi.com/dashboard
SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxx

# OR Brave Search API Key
# Create at: https://brave.com/search/api/
BRAVE_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Generation execution mode for scheduler runs
# `legacy` keeps monolithic generation; `graph` enables single-brief graph flow (Phase 2 starter).
GENERATION_MODE=legacy

# ===========================================
# Redis (for rate limiting in production)
# ===========================================

# Redis connection URL (optional — falls back to in-memory if not set)
# REDIS_URL=redis://localhost:6379

# ===========================================
# Server Configuration
# ===========================================

# API Server Port
PORT=3001

# CORS Origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,https://zerotoship.dev,https://www.zerotoship.dev

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Node Environment
NODE_ENV=development

# ===========================================
# Stripe Configuration (Payments)
# ===========================================

# Stripe Secret Key (from Stripe Dashboard > Developers > API keys)
# Use sk_test_* for development, sk_live_* for production
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Stripe Webhook Secret (from Stripe Dashboard > Developers > Webhooks)
# Create webhook endpoint pointing to: https://your-domain.com/api/webhooks/stripe
# Events: checkout.session.completed, customer.subscription.updated,
#          customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Price IDs — run `npx ts-node scripts/stripe-setup.ts` to create
# Run separately for test + live modes (each creates different price IDs)
STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO_YEARLY=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENT_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENT_YEARLY=price_xxxxxxxxxxxxxxxxxxxx

# Checkout Redirect URLs — MUST use production domain in production
# Example production values:
#   CHECKOUT_SUCCESS_URL=https://zerotoship.dev/account?session_id={CHECKOUT_SESSION_ID}
#   CHECKOUT_CANCEL_URL=https://zerotoship.dev/pricing
#   BILLING_PORTAL_RETURN_URL=https://zerotoship.dev/account
CHECKOUT_SUCCESS_URL=http://localhost:3000/account?session_id={CHECKOUT_SESSION_ID}
CHECKOUT_CANCEL_URL=http://localhost:3000/pricing
BILLING_PORTAL_RETURN_URL=http://localhost:3000/account
