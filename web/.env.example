# ZeroToShip Web Environment Variables

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Supabase (required for OAuth login)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth (required for Google sign-in popup flow)
# Get your client ID at https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional: PostHog Product Analytics
# Get your key at https://posthog.com → Project Settings → Project API Key
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
