{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "paths": {
      "@zerotoship/shared": ["./packages/shared/src/index"],
      "@zerotoship/shared/*": ["./packages/shared/src/*"]
    }
  },
  "include": ["src/**/*", "packages/shared/src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
